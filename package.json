{
  "name": "bookmark-cli-extention",
  "version": "1.3.2",
  "description": "Bookmark CLI browser extension built with WXT.",
  "type": "module",
  "private": true,
  "license": "MIT",
  "packageManager": "pnpm@10.30.0",
  "scripts": {
    "build": "wxt build",
    "build:firefox": "wxt build -b firefox",
    "check": "pnpm run compile && pnpm run lint && pnpm run format:check",
    "compile": "wxt prepare && tsc --noEmit",
    "dev": "wxt",
    "dev:firefox": "wxt -b firefox",
    "docs:archive": "tsx tools/docs-version-archive.ts",
    "docs:build": "pnpm --dir docs run build",
    "docs:check": "pnpm --dir docs run check",
    "docs:dev": "pnpm --dir docs run dev",
    "docs:lint:text": "pnpm --dir docs run lint:text",
    "docs:lint:text:fix": "pnpm --dir docs run lint:text:fix",
    "docs:preview": "pnpm --dir docs run preview",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "pnpm run lint:oxlint && pnpm run lint:docs",
    "lint:docs": "eslint \"**/*.{ts,tsx}\"",
    "lint:jsdoc-style": "eslint \"**/*.{ts,tsx}\" --rule \"bookmark-jsdoc-style/no-desu-ending:error\"",
    "lint:fix": "oxlint --fix . && eslint \"**/*.{ts,tsx}\" --fix",
    "lint:oxlint": "oxlint .",
    "lint:secrets": "secretlint \"**/*\"",
    "postinstall": "wxt prepare",
    "storybook": "storybook dev -p 6006",
    "storybook:build": "storybook build",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:storybook": "storybook build --test",
    "test:watch": "vitest",
    "zip": "wxt zip",
    "zip:amo-sources": "tsx tools/amo-source-package.ts",
    "zip:firefox": "wxt zip -b firefox"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@secretlint/secretlint-rule-preset-recommend": "^12.3.1",
    "@storybook/addon-docs": "^10.4.0",
    "@storybook/react-vite": "^10.4.0",
    "@tailwindcss/vite": "^4.3.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typia/unplugin": "^12.1.1",
    "@vitest/coverage-v8": "^4.1.6",
    "@wxt-dev/module-react": "^1.2.2",
    "eslint": "^10.4.0",
    "eslint-plugin-jsdoc": "^62.9.0",
    "globals": "^17.6.0",
    "oxlint": "^1.65.0",
    "oxlint-tsgolint": "^0.22.1",
    "prettier": "^3.8.3",
    "secretlint": "^12.3.1",
    "storybook": "^10.4.0",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.22.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.3",
    "vitest": "^4.1.6",
    "wxt": "^0.20.26"
  },
  "dependencies": {
    "fuse.js": "^7.3.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "typia": "^12.1.1"
  }
}
