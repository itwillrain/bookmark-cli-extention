---
import { Icon } from "@astrojs/starlight/components";
import starlightVersionsConfig from "virtual:starlight-versions-config";
import { createPublishedVersionPathname, resolvePublishedVersionFromRouteId } from "./version-routing";

/** 現在表示中ページのStarlight route idです。 */
const routeId = Astro.locals.starlightRoute.entry.id;

/** 現在表示中ページが属する公開済みversionです。 */
const pageVersion = resolvePublishedVersionFromRouteId(starlightVersionsConfig.versions, routeId);

/** 最新の公開済みversionです。 */
const latestPublishedVersion = starlightVersionsConfig.versions[0];

/** 現在表示中ページが旧versionかどうかです。 */
const isOutdatedVersion = Boolean(pageVersion && latestPublishedVersion && pageVersion.slug !== latestPublishedVersion.slug);

/** 最新の公開済みversionへのURLです。 */
const latestPublishedVersionUrl = latestPublishedVersion
  ? createPublishedVersionPathname({
      basePath: import.meta.env.BASE_URL,
      routeId,
      sourceVersion: pageVersion,
      targetVersion: latestPublishedVersion,
    })
  : "/";
---

{
  isOutdatedVersion && pageVersion && (
    <p>
      <Icon name="seti:clock" size="1em" color="var(--sl-color-orange-high)" />
      <span>
        {pageVersion.label ? (
          <Fragment set:html={Astro.locals.t("starlightVersions.outdated.label", { label: pageVersion.label })} />
        ) : (
          <Fragment set:html={Astro.locals.t("starlightVersions.outdated.slug", { slug: pageVersion.slug })} />
        )}{" "}
        <Fragment
          set:html={Astro.locals.t("starlightVersions.link.latest", {
            link: latestPublishedVersionUrl,
          })}
        />
      </span>
    </p>
  )
}

<style>
  p {
    display: flex;
    border: 1px solid var(--sl-color-orange);
    padding: 0.75em 1em;
    background-color: var(--sl-color-orange-low);
    color: var(--sl-color-orange-high);
    width: max-content;
    max-width: 100%;
    align-items: center;
    gap: 0.75em;
    font-size: var(--sl-text-sm);
    line-height: var(--sl-line-height-headings);
  }

  p :global(a) {
    color: var(--sl-color-orange-high);
  }

  p :global(svg) {
    flex-shrink: 0;
  }
</style>
