{
  "name": "bookmark-cli-extension-docs",
  "version": "1.2.0",
  "description": "Documentation site for Bookmark CLI Extension.",
  "type": "module",
  "private": true,
  "license": "MIT",
  "packageManager": "pnpm@10.30.0",
  "scripts": {
    "astro": "astro",
    "build": "pnpm run storybook:build && pnpm run check && astro build && pnpm run storybook:copy",
    "check": "pnpm run lint:text && astro check",
    "dev": "astro dev",
    "lint:text": "textlint \"src/content/docs/**/*.md\"",
    "lint:text:fix": "textlint \"src/content/docs/**/*.md\" --fix",
    "preview": "astro preview",
    "storybook:build": "pnpm --dir .. run storybook:build",
    "storybook:copy": "mkdir -p dist/storybook && cp -R ../storybook-static/. dist/storybook/"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.4",
    "@astrojs/starlight": "^0.38.4",
    "@fontsource/inter": "^5.1.1",
    "@fontsource/jetbrains-mono": "^5.1.1",
    "@six-tech/starlight-theme-six": "^1.0.13",
    "astro": "^6.2.1",
    "starlight-versions": "^0.8.2",
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "starlight-typedoc": "^0.21.5",
    "textlint": "^15.6.0",
    "textlint-filter-rule-comments": "^1.3.0",
    "textlint-rule-preset-ja-spacing": "^2.4.3",
    "textlint-rule-preset-ja-technical-writing": "^12.0.2",
    "typedoc": "^0.28.19",
    "typedoc-plugin-markdown": "^4.11.0"
  }
}
